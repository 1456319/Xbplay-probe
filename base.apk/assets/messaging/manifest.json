{
  "manifest_version": 2,
  "name": "browser",
  "version": "1.0",
  "description": "Browser messages for xbgamestream",
  "browser_specific_settings": {
    "gecko": {
      "id": "browser@xbgamestream.com"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["background.js"]
    }
  ],
  "permissions": [
    "nativeMessaging",
    "nativeMessagingFromContent",
    "geckoViewAddons"
  ]
}